# ==============================================================================
# Restaurant Management System (RMS) - .gitignore
# ==============================================================================

# 📦 Dependencies
node_modules/
.pnp
.pnp.js

# 🚀 Build & Production Output
dist/
build/
out/
.vite/

# 🛠️ Testing & Coverage
coverage/
.nyc_output/

# 🔐 Environment Variables & Secrets (สำคัญมาก ห้ามเอาขึ้นเด็ดขาด!)
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# 🗄️ Database & Prisma
*.db
*.db-journal
*.sqlite
*.sqlite3

# 📝 Logs & Diagnostics
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ⚙️ Runtime & Caching
pids
*.pid
*.seed
*.pid.lock
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# 💻 OS Generated Files (ไฟล์ระบบปฏิบัติการ)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 🧰 IDEs & Editors (ไฟล์ตั้งค่าโปรแกรมเขียนโค้ด)
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
